{
  "name": "bayleaf-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-31",
  "compatibility_flags": ["nodejs_compat"],
  
  // Observability - disabled to avoid unnecessary data accumulation.
  // Re-enable temporarily for debugging if needed.
  "observability": {
    "enabled": false
  },

  "routes": [
    { "pattern": "api.bayleaf.dev", "custom_domain": true }
  ],

  // D1 database for proxy key mappings
  // Create with: wrangler d1 create bayleaf-keys
  // Then run migration: wrangler d1 migrations apply bayleaf-keys
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bayleaf-keys",
      "database_id": "e249d6a6-41cf-4ab7-93d6-b677ac95b524"
    }
  ],

  // KV namespace for Campus Pass per-IP RPD counters.
  // Keys: `campus-rpd:<bucket>:<YYYY-MM-DD>` → JSON `{count: number}`, TTL 36h.
  // Created via: wrangler kv namespace create CAMPUS_RPD
  //
  // KV namespace for the generic /auth/claim/* device-flow handshake.
  // Keys: `claim:<CODE>` → JSON ClaimRecord (see routes/claim.ts), TTL 600s.
  // Created via: wrangler kv namespace create CLAIM_CODES
  "kv_namespaces": [
    {
      "binding": "CAMPUS_RPD",
      "id": "6b839ccbc7d14ddb86af4d7cb926eed2"
    },
    {
      "binding": "CLAIM_CODES",
      "id": "f435dc71d19148bab46fb0b14b99de2b"
    }
  ],

  // Environment variables (set via wrangler secret or dashboard)
  // These are placeholders - actual values should be set as secrets
  "vars": {
    // GCP Vertex AI Configuration
    //
    // VERTEX_ENABLED is the master kill-switch for the Vertex backend. It must
    // be exactly the string "true" to enable any `vertex:` routing, model
    // listing, or curated-model exposure. Any other value (including the empty
    // string or omission) disables Vertex entirely: `vertex:` chat completions
    // are rejected with 503, Vertex models are dropped from GET /models, and
    // `vertex:` entries are stripped from the OpenCode curated list.
    //
    // Disabled pending a credible zero-data-retention path with Google. The
    // project-level Abuse Monitoring opt-out request never received a response,
    // so we cannot promise ZDR parity with our OpenRouter path (issue #36).
    "VERTEX_ENABLED": "false",
    "GCP_PROJECT_ID": "bayleafchat",
    "GCP_REGION": "us-central1",
    // GCP_SERVICE_ACCOUNT_EMAIL and GCP_SERVICE_ACCOUNT_PRIVATE_KEY should be set via `wrangler secret put`

    "SPENDING_LIMIT_DOLLARS": "5.0",
    "SPENDING_LIMIT_RESET": "daily",
    "KEY_NAME_TEMPLATE": "BayLeaf API for $email",
    "ALLOWED_EMAIL_DOMAIN": "ucsc.edu",
    "SYSTEM_PROMPT_PREFIX": "You are accessing the BayLeaf API (https://api.bayleaf.dev/),  UC Santa Cruz's locally-operated AI service. Help users develop capability they can carry forward—into their own work and into collaboration with others. Make reasoning visible. Teach what generalizes. Conversations are private and never used for training.",
    
    // Campus Pass: allow on-campus users to access without personal API keys
    "RECOMMENDED_MODEL": "openrouter:z-ai/glm-5.1",

    // Curated companion models for the OpenCode wellknown remote config.
    // Comma-separated namespaced slugs (openrouter: / vertex:). RECOMMENDED_MODEL is
    // injected automatically as the first entry; this list adds further picks the
    // user can select from /models in OpenCode without a full /v1/models browse.
    // Empty string is allowed and means "recommended model only".
    "OPENCODE_CURATED_MODELS": "openrouter:qwen/qwen3.6-27b,vertex:zai-org/glm-5-maas",

    // OIDC authentication — provider-agnostic via .well-known discovery.
    // Currently configured for CILogon (https://www.cilogon.org/oidc).
    // For Google, use:
    //   OIDC_ISSUER: "https://accounts.google.com"
    //   OIDC_SCOPES: "openid email profile"
    //   OIDC_AUTHORIZE_PARAMS: "hd=ucsc.edu"
    //   OIDC_LOGIN_BUTTON_TEXT: "Sign in with UCSC Google"
    "OIDC_ISSUER": "https://cilogon.org",
    "OIDC_SCOPES": "openid email profile org.cilogon.userinfo",
    "OIDC_AUTHORIZE_PARAMS": "idphint=urn:mace:incommon:ucsc.edu",
    "OIDC_LOGIN_BUTTON_TEXT": "Sign in with UCSC",

    // Campus Pass: allow on-campus users to access without personal API keys
    // Set CAMPUS_IP_RANGES to enable (empty string = disabled)
    "CAMPUS_IP_RANGES": "128.114.0.0/16,169.233.0.0/16,192.35.220.0/24,192.35.223.0/24,2607:F5F0::/32,127.0.0.1/32,::1/128",
    "CAMPUS_SYSTEM_PREFIX": "Note: This user is accessing the API via shared on-campus access. They can provision a personal API key at no cost by visiting https://api.bayleaf.dev/",
    // Per-IP daily request limit for Campus Pass on /chat/completions and /responses.
    // IPv4: per address. IPv6: per /64. Resets at midnight UTC. Provider-agnostic
    // (charges against the same counter for OpenRouter and Vertex traffic).
    "CAMPUS_RPD_LIMIT": "100",

    // Sandbox: sandboxed code execution via Daytona
    "DAYTONA_API_URL": "https://app.daytona.io/api",
    "DAYTONA_PROXY_URL": "https://proxy.app.daytona.io/toolbox",
    // Unified with chat.bayleaf.dev (Lathe) so a user has one sandbox across
    // both services. See issue #14. The API never reads/writes the volume
    // mount Lathe may attach at /home/daytona/volume; only /home/daytona/workspace
    // is the shared filesystem surface.
    "DAYTONA_DEPLOYMENT_LABEL": "chat.bayleaf.dev",
    "DAYTONA_AUTO_DELETE_MINUTES": "129600"
  }

  // Secrets to configure via `wrangler secret put`:
  // - OPENROUTER_PROVISIONING_KEY
  // - OIDC_CLIENT_ID       (from your OIDC provider: CILogon, Google, etc.)
  // - OIDC_CLIENT_SECRET   (from your OIDC provider)
  // - CAMPUS_POOL_KEY (for Campus Pass feature)
  // - DAYTONA_API_KEY (for sandbox provider)
  // - GWS_CLIENT_ID        (Google Workspace CLI OAuth client ID)
  // - GWS_CLIENT_SECRET    (Google Workspace CLI OAuth client secret)
  // - GWS_PROJECT_ID       (GCP project ID, e.g. "gws-cli-playground-ucsc")
}
