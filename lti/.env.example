# Copy to .env (which is gitignored) and fill in.
# .env is the ONLY place credentials live. Never paste them into chat,
# commits, issue comments, or anywhere else.

# LTI 1.1 credentials (Plan B path: install via Canvas "Add App > By URL"
# with our /lti/config.xml). The consumer key is shared with Canvas; the
# secret is proven via OAuth 1.0a HMAC-SHA1 on every launch. Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
# Then paste both values into Canvas's Add App form when installing.
LTI_1P1_CONSUMER_KEY=
LTI_1P1_SHARED_SECRET=

# RSA keypair for LTI 1.3 JWKS. In production these are PEM blobs injected
# as DO App Platform secrets; locally they are usually loaded from disk at
# keys/lti_*.pem. Leave both empty for the local-dev disk path.
LTI_PRIVATE_KEY_PEM=
LTI_PUBLIC_KEY_PEM=

# Local-dev opt-in: if neither env vars nor on-disk PEMs are present,
# autogenerate a fresh keypair on disk. The connector REFUSES to start in
# any other under-configured state, so production misconfig is loud.
# Never set this in production.
LTI_DEV_AUTOGEN_KEYS=1

# Debug echo endpoint at /debug/echo. Set to 1 to enable.
# Off by default in production (DO env sets DEBUG_ECHO=0).
DEBUG_ECHO=1

# Override the public hostname the cartridge XML and registration body
# advertise. Defaults to https://lti.bayleaf.dev. Mostly relevant for
# local-dev tunnels or alternate deploys.
# PUBLIC_BASE_URL=
