{
  "name": "bayleaf-courses",
  "main": "src/index.tsx",
  "compatibility_date": "2025-01-31",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  "routes": [
    { "pattern": "courses.bayleaf.dev", "custom_domain": true }
  ]

  // D1, env vars, and secrets are commented out while the service is a teaser page.
  // See git history for the full configuration.
}
